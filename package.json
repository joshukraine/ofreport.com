{
  "name": "ofreport.com",
  "version": "2.0.0",
  "description": "Our family blog, documenting our work in Ukraine",
  "author": "Joshua Steele",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "yarn md2json && nuxt",
    "generate": "yarn md2json && nuxt generate",
    "lint": "eslint --ext .js,.vue . && prettier --check \"**/*.(js|css|vue)\"",
    "lint:fix": "eslint --ext .js,.vue --fix . && prettier --write \"**/*.(js|css|vue)\"",
    "md2json": "m2j -w 0 content/articles/*.md -o data/articles.json",
    "start": "nuxt start",
    "prepare": "husky install"
  },
  "lint-staged": {
    "*.vue": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.css": "prettier --write",
    "*.{js,vue}": "eslint --cache --fix"
  },
  "dependencies": {
    "@nuxtjs/axios": "^5.12.1",
    "@nuxtjs/cloudinary": "^1.0.3",
    "@nuxtjs/feed": "^2.0.0",
    "@nuxtjs/recaptcha": "1.1.2",
    "@nuxtjs/robots": "^2.4.2",
    "@nuxtjs/sitemap": "^2.4.0",
    "@nuxtjs/toast": "^3.3.1",
    "cloudinary-vue": "^1.2.2",
    "concurrent-transform": "^1.0.0",
    "current-script-polyfill": "^1.0.0",
    "dayjs": "1.11.13",
    "frontmatter-markdown-loader": "^3.6.0",
    "lodash.countby": "^4.6.0",
    "markdown-it": "13.0.2",
    "markdown-it-link-attributes": "^4.0.0",
    "markdown-to-json": "^0.5.1",
    "nuxt": "2.18.1",
    "tailwindcss": "^1.9.6",
    "vuejs-paginate": "^2.1.0",
    "vuelidate": "^0.7.4"
  },
  "resolutions": {
    "cipher-base": "^1.0.5",
    "sha.js": "^2.4.12",
    "pbkdf2": "^3.1.3",
    "elliptic": "^6.6.1",
    "vm2": "^3.10.2",
    "lodash": "^4.17.23",
    "js-yaml": "^3.14.2",
    "@babel/runtime": "^7.26.10",
    "brace-expansion": "^1.1.12",
    "koa": "^2.16.2",
    "on-headers": "^1.1.0",
    "tmp": "^0.2.4"
  },
  "devDependencies": {
    "@babel/plugin-proposal-private-property-in-object": "^7.21.11",
    "@nuxtjs/google-analytics": "^2.4.0",
    "@nuxtjs/tailwindcss": "4.0.0",
    "babel-eslint": "^10.0.3",
    "eslint": "7.32.0",
    "eslint-config-airbnb-base": "^14.2.0",
    "eslint-config-prettier": "^8.3.0",
    "eslint-plugin-import": "^2.24.1",
    "eslint-plugin-jsx-a11y": "^6.3.1",
    "eslint-plugin-prettier": "^3.4.1",
    "eslint-plugin-vue": "^7.16.0",
    "husky": "^7.0.1",
    "lint-staged": "^11.1.2",
    "prettier": "2.5.1"
  }
}
